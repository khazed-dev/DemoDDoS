NODE_ENV=production
VICTIM_PORT=3001
DASHBOARD_PORT=3002
VICTIM_PUBLIC_NAME=Victim Website
VICTIM_HEAVY_DEFAULT_MS=80
VICTIM_HEAVY_MAX_MS=220
VICTIM_REPORT_DELAY_MS=650
VICTIM_OVERLOAD_INFLIGHT=24
VICTIM_LOG_DIR=./data/raw
VICTIM_METRICS_FILE=./data/raw/victim-metrics.jsonl
VICTIM_ACCESS_FILE=./data/raw/victim-access.jsonl
DASHBOARD_SUMMARY_DIR=./data/summaries
DASHBOARD_VICTIM_HEALTH_URL=http://127.0.0.1:3001/health
NGINX_ACCESS_LOG=./data/raw/nginx-access.jsonl
NGINX_ERROR_LOG=./data/raw/nginx-error.log
OPS_EVENTS_LOG=./data/raw/ops-events.jsonl
PARSER_INTERVAL_MS=15000
SUMMARY_RETENTION_EVENTS=400

